<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="8dp"
    android:paddingEnd="24dp"
    android:paddingBottom="4dp">

    <TextView
        android:id="@+id/preset_source_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_preset_source_message"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/preset_source_radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/preset_source_option_default"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_preset_source_option_default" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/preset_source_option_custom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_preset_source_option_custom" />
    </RadioGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/preset_source_input_layout"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="4dp"
        android:hint="@string/settings_preset_source_input_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/preset_source_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:maxLines="1"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:selectAllOnFocus="true" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
