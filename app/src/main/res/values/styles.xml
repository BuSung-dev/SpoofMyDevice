<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.DeviceSpoofLab.Card.Surface" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">?android:attr/colorBackground</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.DeviceSpoofLab.Card.Tonal" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">?android:attr/colorBackground</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutlineVariant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="LegendHeaderSurface">
        <item name="android:background">?android:attr/colorBackground</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">5dp</item>
        <item name="android:paddingEnd">5dp</item>
    </style>

    <style name="LegendHeaderTonal">
        <item name="android:background">?android:attr/colorBackground</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">5dp</item>
        <item name="android:paddingEnd">5dp</item>
    </style>

    <style name="TextAppearance.DeviceSpoofLab.CollapsingExpanded" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">30sp</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>

    <style name="TextAppearance.DeviceSpoofLab.CollapsingCollapsed" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>
</resources>
